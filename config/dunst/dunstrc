[global]
frame_color = "#89b4fa"
separator_color= frame
font = "JetBrainsMono 11"
corner_radius = 10
padding = 12
idle_threshold = 120
origin = top-center
width = (400, 800)

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
